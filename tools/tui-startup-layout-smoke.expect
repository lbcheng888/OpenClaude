#!/usr/bin/expect -f
# Startup screen layout verification at 80/120/137 columns
set timeout 10
set repo [file normalize [file join [file dirname [info script]] ".."]]
set workdir "/tmp/claude-code-full-startup-layout-smoke"
file mkdir $workdir
cd $workdir

set env(TERM) xterm-256color
set env(HOME) "/tmp/claude-code-full-startup-layout-home"
set env(CLAUDE_CONFIG_DIR) "/tmp/claude-code-full-startup-layout-home/.claude"
file mkdir $env(CLAUDE_CONFIG_DIR)
catch {unset env(ANTHROPIC_AUTH_TOKEN)}
catch {unset env(ANTHROPIC_API_KEY)}
catch {unset env(ANTHROPIC_BASE_URL)}
catch {unset env(ANTHROPIC_MODEL)}
catch {unset env(ANTHROPIC_DEFAULT_HAIKU_MODEL)}
catch {unset env(ANTHROPIC_DEFAULT_OPUS_MODEL)}
catch {unset env(ANTHROPIC_DEFAULT_SONNET_MODEL)}
catch {unset env(CLAUDE_CODE_EFFORT_LEVEL)}
catch {unset env(CLAUDE_CODE_SUBAGENT_MODEL)}

# Test 80 columns
set env(COLUMNS) 80
spawn -noecho node [file join $repo dist index.js] --dangerously-skip-permissions
expect "Claude Code v2.1.128"
expect "Welcome"
expect "Tips for getting started"
send "\003\003"
expect eof
puts "PASS: 80 columns layout"

# Test 120 columns
set env(COLUMNS) 120
spawn -noecho node [file join $repo dist index.js] --dangerously-skip-permissions
expect "Claude Code v2.1.128"
expect "Welcome"
expect "Tips for getting started"
send "\003\003"
expect eof
puts "PASS: 120 columns layout"

# Test 137 columns
set env(COLUMNS) 137
spawn -noecho node [file join $repo dist index.js] --dangerously-skip-permissions
expect "Claude Code v2.1.128"
expect "Welcome"
expect "Tips for getting started"
send "\003\003"
expect eof
puts "PASS: 137 columns layout"

puts "ALL PASS"
