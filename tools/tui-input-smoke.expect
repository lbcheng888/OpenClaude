#!/usr/bin/env expect
set timeout 10
set repo [file normalize [file join [file dirname [info script]] ".."]]
set workdir "/tmp/claude-code-full-smoke-work"
file mkdir $workdir
cd $workdir
set env(COLUMNS) 100
set env(TERM) xterm-256color
set env(HOME) "/tmp/claude-code-full-smoke-home"
set env(CLAUDE_CONFIG_DIR) "/tmp/claude-code-full-smoke-home/.claude"
file mkdir $env(CLAUDE_CONFIG_DIR)
catch {unset env(ANTHROPIC_AUTH_TOKEN)}
catch {unset env(ANTHROPIC_API_KEY)}
catch {unset env(ANTHROPIC_BASE_URL)}
catch {unset env(ANTHROPIC_MODEL)}
catch {unset env(ANTHROPIC_DEFAULT_HAIKU_MODEL)}
catch {unset env(ANTHROPIC_DEFAULT_OPUS_MODEL)}
catch {unset env(ANTHROPIC_DEFAULT_SONNET_MODEL)}
catch {unset env(CLAUDE_CODE_EFFORT_LEVEL)}
catch {unset env(CLAUDE_CODE_SUBAGENT_MODEL)}
spawn -noecho node [file join $repo dist index.js] --dangerously-skip-permissions
expect "Claude Code v2.1.131"
send "?"
expect "Available commands:"
send "\033\[B"
expect "No background tasks."
send "/doctor\r"
expect "cwd:"
expect "auth:"
send "/model claude-opus-4-6\r"
expect "Model set to claude-opus-4-6"
send "/model\r"
expect "Current model: claude-opus-4-6"
send "/cost\r"
expect "Total cost:"
expect "Usage:"
send "/tasks\r"
expect "No background tasks."
send "/tasks missing-task\r"
expect "Background task not found: missing-task"
send "/tasks stop\r"
expect "Usage:"
send "\003\003\003"
expect eof
